---
const {
  title = 'Home Office Gear',
  description = 'Practical home office gear guides for remote workers, small spaces, and ergonomic desk setups.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Home Office Gear</a>
      <nav>
        <a href="/posts/">Guides</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Independent home office buying guides and setup tutorials.</p>
    </footer>
  </body>
</html>
