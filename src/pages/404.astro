---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = import.meta.glob('../../content/posts/*.md', { eager: true });
const recent = Object.entries(modules)
  .map(([path, mod]: [string, any]) => {
    const fm = mod.frontmatter ?? {};
    return {
      slug: fm.slug ?? path.split('/').pop()?.replace(/\.md$/, ''),
      title: fm.title ?? 'Untitled',
      date: fm.pubDate ?? fm.date ?? '',
    };
  })
  .sort((a, b) => (b.date > a.date ? 1 : -1))
  .slice(0, 6);
---
<BaseLayout title="Page Not Found | Home Office Gear" description="The page you requested could not be found. Try our most recent posts.">
  <div class="not-found">
    <h1>404 — Page Not Found</h1>
    <p class="lead">Sorry, the page you're looking for doesn't exist or has moved.</p>
    <p><a class="btn" href="/">← Back to homepage</a></p>

    <hr />

    <h2>Recent Posts</h2>
    <ul class="recent">
      {recent.map(p => (
        <li><a href={`/posts/${p.slug}/`}>{p.title}</a></li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .not-found { max-width: 720px; margin: 0 auto; padding: 3rem 1.25rem; text-align: center; }
  .not-found h1 { font-size: 2rem; margin-bottom: 1rem; }
  .not-found .lead { color: #4b5563; font-size: 1.1rem; margin-bottom: 1.5rem; }
  .not-found .btn {
    display: inline-block; padding: .75rem 1.25rem;
    background: #111827; color: #fff; border-radius: 6px;
    text-decoration: none; font-weight: 500;
  }
  .not-found hr { margin: 2.5rem auto; border: none; border-top: 1px solid #e5e7eb; max-width: 200px; }
  .not-found h2 { font-size: 1.25rem; margin-bottom: 1rem; }
  .not-found .recent { list-style: none; padding: 0; text-align: left; max-width: 480px; margin: 0 auto; }
  .not-found .recent li { margin: .5rem 0; }
  .not-found .recent a { color: #2563eb; text-decoration: none; }
  .not-found .recent a:hover { text-decoration: underline; }
</style>
