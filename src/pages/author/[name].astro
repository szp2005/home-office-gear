---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../../content/posts/*.md', { eager: true });
  const posts = Object.entries(modules).map(([path, mod]) => {
    const fm = (mod as any).frontmatter ?? {};
    return {
      frontmatter: fm,
      slug: fm.slug ?? path.split('/').pop()?.replace(/\.md$/, ''),
      sortKey: String(fm.pubDate ?? fm.date ?? ''),
    };
  });

  const authors = [...new Set(posts.map(p => p.frontmatter.author).filter(Boolean))] as string[];

  return authors.map(author => {
    const authorPosts = posts
      .filter(p => p.frontmatter.author === author)
      .sort((a, b) => (b.sortKey > a.sortKey ? 1 : -1));
    return {
      params: { name: String(author).toLowerCase().replace(/\s+/g, '-') },
      props: { author, posts: authorPosts }
    };
  });
}

const { author, posts } = Astro.props as { author: string; posts: Array<{ frontmatter: any; slug: string }> };
const siteName = 'Home Office Gear';
const siteURL = 'https://gear.toolrouteai.com';

const bios: Record<string, string> = {
  "Sarah Miller": "Sarah Miller is a certified ergonomist and home office design consultant with over 12 years of experience helping remote workers create healthier, more productive workspaces. With a background in physical therapy, she evaluates standing desks, chairs, monitors, and accessories through the lens of long-term well-being and practical daily use.",
  "Alex Chen": "Alex Chen is a productivity researcher and tech reviewer specializing in home office setups and workflow automation tools."
};

const bio = bios[author] ?? `Expert contributor at ${siteName}, specializing in ergonomic home office equipment reviews and setup guides.`;
const canonicalURL = `${siteURL}/author/${String(author).toLowerCase().replace(/\s+/g, '-')}/`;
---
<BaseLayout
  title={`Articles by ${author} | ${siteName}`}
  description={`Read all articles and reviews written by ${author} on ${siteName}.`}
  canonicalURL={canonicalURL}
>
  <div class="author-page">
    <header class="author-header">
      <div class="author-info">
        <h1>{author}</h1>
        <p class="bio">{bio}</p>
      </div>
    </header>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": author,
      "description": bio,
      "url": canonicalURL,
      "knowsAbout": posts.slice(0, 10).map(p => p.frontmatter.title).filter(Boolean),
      "worksFor": {
        "@type": "Organization",
        "name": siteName,
        "url": siteURL
      }
    })} />
    <section class="author-posts">
      <h2>Published Reviews ({posts.length})</h2>
            <ul class="post-list">
        {posts.map(post => (
          <li>
            <a href={`/posts/${post.slug}/`}>{post.frontmatter.title}</a>
            {post.frontmatter.description && <p class="excerpt">{post.frontmatter.description}</p>}
            {(post.frontmatter.pubDate ?? post.frontmatter.date) && (
              <span class="date">{String(post.frontmatter.pubDate ?? post.frontmatter.date)}</span>
            )}
          </li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
.author-page { max-width: 820px; margin: 0 auto; padding: 2rem 1rem; }
.author-header { margin-bottom: 3rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 2rem; }
.author-info h1 { font-size: 2.5rem; margin: 0 0 1rem 0; }
.bio { font-size: 1.1rem; line-height: 1.6; color: #4b5563; margin: 0; }
.author-posts h2 { font-size: 1.5rem; margin-bottom: 1.5rem; }
.post-list { list-style: none; padding: 0; }
.post-list li { margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.25rem; }
.post-list a { font-size: 1.1rem; font-weight: 600; color: #2563eb; text-decoration: none; }
.post-list a:hover { text-decoration: underline; }
.post-list .excerpt { font-size: 0.95rem; color: #4b5563; margin: 0.25rem 0 0.35rem; line-height: 1.5; }
.date { font-size: 0.9rem; color: #6b7280; }
</style>
