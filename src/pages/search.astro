---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Search | Home Office Gear" description="Search all articles on Home Office Gear.">
  <div class="search-page">
    <h1>Search</h1>
    <p class="hint">Search across all articles. Results appear instantly as you type.</p>

    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <div id="search"></div>

    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        new PagefindUI({ element: '#search', showSubResults: true, resetStyles: false });
      });
    </script>
  </div>
</BaseLayout>

<style>
  .search-page { max-width: 820px; margin: 0 auto; padding: 2.5rem 1.25rem; }
  .search-page h1 { font-size: 2rem; margin-bottom: .5rem; }
  .search-page .hint { color: #6b7280; margin-bottom: 1.5rem; }
  :global(.pagefind-ui__search-input) { font-size: 1.05rem; padding: .75rem 1rem; }
</style>
